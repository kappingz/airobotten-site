{% block scripts %}
<script>
  function toggleFaq(b) {
    var i = b.closest('.faq-item'), w = i.classList.contains('active');
    document.querySelectorAll('.faq-item').forEach(function(x) { x.classList.remove('active'); });
    if (!w) i.classList.add('active');
  }
</script>
