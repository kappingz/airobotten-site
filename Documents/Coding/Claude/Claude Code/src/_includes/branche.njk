{% extends "base.njk" %}

{% block extraCSS %}
  .page-content { max-width: 720px; margin: 0 auto; padding: 8rem 2rem 4rem; }

  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: var(--text-light);
    margin-bottom: 2.5rem;
  }
  .breadcrumb a { transition: color 0.3s; }
  .breadcrumb a:hover { color: var(--text); }
  .breadcrumb .sep { opacity: 0.4; }

  .page-category {
    font-family: var(--font-mono);
    font-size: 0.68rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--accent);
    font-weight: 500; margin-bottom: 0.8rem;
  }

  .page-content h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 400; line-height: 1.15;
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: var(--font-mono); font-size: 0.65rem;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);
    font-weight: 500; margin-bottom: 0.6rem; margin-top: 2.5rem;
  }

  .page-content h2 {
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: 400;
    margin-bottom: 0.8rem; margin-top: 2.5rem;
  }

  .page-content p {
    font-size: 1rem; line-height: 1.75;
    color: var(--text-muted); margin-bottom: 1.2rem;
  }

  /* NUMBERED STEPS (tidssluger) */
  .steps { list-style: none; margin: 0.8rem 0 2rem; display: flex; flex-direction: column; gap: 1.1rem; padding: 0; }
  .steps li {
    display: flex; gap: 1.2rem; align-items: flex-start;
    padding: 1.2rem 1.4rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .steps li .step-num {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
    color: var(--accent); min-width: 2rem; padding-top: 0.15rem; flex-shrink: 0;
  }
  .steps li .step-body { font-size: 0.95rem; line-height: 1.65; color: var(--text-muted); }
  .steps li .step-body strong { color: var(--text); display: block; margin-bottom: 0.25rem; font-size: 0.97rem; }

  /* BENEFIT LIST */
  .benefit-list { list-style: none; margin: 0.5rem 0 2rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .benefit-list li {
    font-size: 0.95rem; line-height: 1.6; color: var(--text-muted);
    padding-left: 1.4rem; position: relative;
  }
  .benefit-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.8rem; }

  /* FLOW DIAGRAM */
  .flow-diagram {
    display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
    padding: 1.2rem 1.4rem; margin: 0.6rem 0;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .flow-node {
    padding: 0.5rem 1rem;
    background: var(--bg); border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-size: 0.82rem; font-weight: 500; color: var(--text);
    white-space: nowrap;
  }
  .flow-arrow { color: var(--accent); font-size: 1.1rem; opacity: 0.6; }
  .flow-tool {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    background: var(--accent-soft); color: var(--accent);
    border-radius: 4px; border: 1px solid rgba(42,92,255,0.15);
    white-space: nowrap;
  }
  .automationer-list { display: flex; flex-direction: column; gap: 0.8rem; margin: 0.8rem 0 2rem; }

  /* CASE STUDY */
  .case-study {
    margin-top: 2.5rem; padding: 1.6rem 1.8rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .case-label {
    display: inline-block; font-family: var(--font-mono);
    font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.2rem 0.6rem; background: var(--orange-soft);
    color: var(--orange); border-radius: 4px; margin-bottom: 0.8rem;
  }
  .case-study h3 {
    font-family: var(--font-display); font-size: 1.1rem;
    font-weight: 400; margin-bottom: 0.7rem; margin-top: 0.4rem;
  }
  .case-study p { font-size: 0.95rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 0.8rem; }
  .case-study p:last-child { margin-bottom: 0; }

  /* IMPLEMENTATION STEPS */
  .impl-steps { display: flex; flex-direction: column; gap: 1rem; margin: 0.8rem 0 2rem; }
  .impl-step { display: flex; gap: 1.2rem; align-items: flex-start; }
  .impl-num {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
    color: var(--accent); min-width: 2rem; padding-top: 0.15rem; flex-shrink: 0;
  }
  .impl-step p { font-size: 0.95rem; line-height: 1.65; color: var(--text-muted); margin-bottom: 0; }
  .impl-step p strong { color: var(--text); display: block; margin-bottom: 0.2rem; }

  /* FAQ DETAILS */
  .faq-details { margin-top: 0.5rem; }
  .faq-details details { border-bottom: 1px solid var(--border); }
  .faq-details details:first-child { border-top: 1px solid var(--border); }
  .faq-details summary {
    cursor: pointer; padding: 0.85rem 0; font-weight: 600;
    font-size: 0.93rem; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem; color: var(--text);
  }
  .faq-details summary::-webkit-details-marker { display: none; }
  .faq-details summary::after { content: '+'; color: var(--accent); font-size: 1.1rem; font-weight: 400; flex-shrink: 0; }
  .faq-details details[open] > summary::after { content: '−'; }
  .faq-details details p { padding: 0 0 0.9rem; font-size: 0.95rem; color: var(--text-muted); }

  /* CTA BOX */
  .cta-box {
    margin-top: 3.5rem; padding: 2.5rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); text-align: center;
  }
  .cta-box h3 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; margin-bottom: 0.6rem; }
  .cta-box h3 em { font-style: italic; color: var(--accent); }
  .cta-box p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6; }

  /* RELATED */
  .related { margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--border); }
  .related h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 400; margin-bottom: 1.5rem; }
  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .related-card {
    padding: 1.3rem 1.4rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); transition: all 0.3s;
  }
  .related-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .related-card h4 { font-size: 0.88rem; font-weight: 600; margin-bottom: 0.25rem; }
  .related-card p { font-size: 0.75rem; color: var(--text-light); margin-bottom: 0; }

  @media (max-width: 768px) {
    .page-content { padding: 7rem 1.5rem 3rem; }
    .related-grid { grid-template-columns: 1fr; }
    .flow-diagram { flex-direction: column; align-items: flex-start; }
    .flow-arrow { transform: rotate(90deg); }
  }
{% endblock %}

{% block head %}
{% if faq_schema %}
<script type="application/ld+json">{{ faq_schema | safe }}</script>
{% endif %}
{% endblock %}

{% block content %}
<div class="page-content">

  <div class="breadcrumb">
    <a href="/">Forside</a>
    <span class="sep">›</span>
    <span>AI-automatisering til {{ branche }}</span>
  </div>

  <div class="page-category">Branche</div>
  <h1>{{ title }}</h1>

  {% if intro %}
  {{ intro | safe }}
  {% endif %}

  {% if tidssluger %}
  <div class="section-label">De 3 største tidssluger</div>
  <h2>Hvad koster din tid som {{ branche_kort if branche_kort else branche }}?</h2>
  <ol class="steps">
    {% for t in tidssluger %}
    <li>
      <div class="step-num">{{ loop.index | string | padStart(2, '0') }}</div>
      <div class="step-body"><strong>{{ t.title }}</strong>{{ t.body }}</div>
    </li>
    {% endfor %}
  </ol>
  {% endif %}

  {% if fordele %}
  <div class="section-label">Hvad automatisering løser</div>
  <h2>Konkrete gevinster ved digitalisering i {{ branche }}</h2>
  <ul class="benefit-list">
    {% for f in fordele %}<li>{{ f }}</li>{% endfor %}
  </ul>
  {% endif %}

  {% if automationer %}
  <div class="section-label">Populære automationer i branchen</div>
  <h2>Automationsflows der virker for {{ branche }}</h2>
  <div class="automationer-list">
    {% for a in automationer %}
    <div class="flow-diagram">
      <div class="flow-node">{{ a.trigger }}</div>
      <div class="flow-arrow">→</div>
      <div class="flow-tool">{{ a.tool }}</div>
      <div class="flow-arrow">→</div>
      <div class="flow-node">{{ a.result }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if case %}
  <div class="section-label">Resultat i praksis</div>
  <div class="case-study">
    <span class="case-label">Eksempel — fiktiv case</span>
    <h3>{{ case.name }}</h3>
    {{ case.body | safe }}
  </div>
  {% endif %}

  {% if impl_steps %}
  <div class="section-label">Kom i gang på 30 dage</div>
  <h2>Realistisk implementering for en travl {{ branche_kort if branche_kort else branche }}</h2>
  <div class="impl-steps">
    {% for s in impl_steps %}
    <div class="impl-step">
      <div class="impl-num">{{ loop.index | string | padStart(2, '0') }}</div>
      <p><strong>{{ s.title }}</strong>{{ s.body }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if faq %}
  <div class="section-label">Spørgsmål fra branchen</div>
  <div class="faq-details">
    {% for item in faq %}
    <details>
      <summary>{{ item.q }}</summary>
      <p>{{ item.a }}</p>
    </details>
    {% endfor %}
  </div>
  {% endif %}

  <div class="cta-box">
    <h3>Spar tid i din <em>{{ branche }}</em> fra næste måned</h3>
    <p>Beskriv hvilke opgaver der tager mest tid i din hverdag, og vi vurderer uforpligtende hvilke der kan automatiseres — og hvad du realistisk kan spare.</p>
    <a href="/#contact" class="btn-primary">
      Send din opgave
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  {% if related %}
  <div class="related">
    <h3>Relevante automatiseringer</h3>
    <div class="related-grid">
      {% for card in related %}
      <a href="{{ card.url }}" class="related-card">
        <h4>{{ card.title }}</h4>
        <p>{{ card.category }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}
